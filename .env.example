# mnemosyne production / SaaS — copy to .env and fill secrets (never commit .env)

# --- Core ---
MNEMOSYNE_SECRET_KEY=CHANGE_ME_generate_with_python_-c_import_secrets_print_secrets_token_hex_32
MNEMOSYNE_DB=mnemosyne.db
MNEMOSYNE_PORT=8000

# Public origin for share links (pasteable off-box). Set via scripts/wire-public-url.sh
# MNEMOSYNE_PUBLIC_URL=https://mnemosyne.example.com

# Optional Plutus base for path-only print offer links
# MNEMOSYNE_PLUTUS_URL=https://plutus.example.com
# MNEMOSYNE_PLUTUS_API_TOKEN=   # Plutus admin Bearer token
# MNEMOSYNE_PLUTUS_TENANT_ID=flow-studio   # SaaS tenant for offer links (admin API)
# MNEMOSYNE_PLUTUS_AUTO_LINK=true          # worker mints offer when album ready + run id set
# MNEMOSYNE_PLUTUS_RUN_ID=                 # fallback bundles run id (optional)

# Mise gallery import — scripts/wire-mise.sh
# MNEMOSYNE_MISE_URL=http://flow:8400
# MNEMOSYNE_MISE_API_TOKEN=                # same bearer as MISE_ARGUS_TOKEN on flow
# MNEMOSYNE_MISE_MEDIA_ROOT=               # local sync root (plutus sync-mise-media.sh)
# Per-asset signal endpoint ({gallery_id} template). Override only if Mise's route
# differs; the client tolerates the response shape and falls back to local vision.
# MNEMOSYNE_MISE_ASSETS_PATH=/api/galleries/{gallery_id}/assets

# Argus vision delegation — scripts/wire-argus.sh
# MNEMOSYNE_ARGUS_URL=http://127.0.0.1:8010
# MNEMOSYNE_ARGUS_API_TOKEN=
# MNEMOSYNE_ARGUS_DELEGATION_MODE=path      # path | upload
# MNEMOSYNE_VISION_BACKEND=argus

# Stripe (off until MNEMOSYNE_STRIPE_ENABLED=true + CPA review)
# MNEMOSYNE_STRIPE_ENABLED=false
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=

# Password reset — log links in journal when SMTP not wired (dogfood only)
# MNEMOSYNE_DEV_RESET_LINKS=true

# --- Storage (local dogfood vs R2 prod) ---
MNEMOSYNE_STORAGE_BACKEND=local
MNEMOSYNE_UPLOAD_DIR=uploads

# R2 — set MNEMOSYNE_STORAGE_BACKEND=r2 and run scripts/wire-r2.sh
# MNEMOSYNE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# MNEMOSYNE_R2_BUCKET=mnemosyne-galleries
# MNEMOSYNE_R2_ACCESS_KEY_ID=
# MNEMOSYNE_R2_SECRET_ACCESS_KEY=
# MNEMOSYNE_R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

# --- Inference (local dogfood default; grok for prod COGS) ---
# MNEMOSYNE_VISION_BACKEND=grok
# MNEMOSYNE_ARRANGE_BACKEND=grok          # grok | deterministic | (unset = local ollama)
# deterministic = lay the album out with the in-repo curate engine (arc-sequenced +
# paced from stored hero/keeper signals, no model, reproducible). Compare it to the
# Mise baseline first with:  python -m mnemosyne eval --album <id>
# XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1
# MNEMOSYNE_GROK_VISION_MODEL=grok-4.20-non-reasoning
# MNEMOSYNE_GROK_ARRANGE_MODEL=grok-4.20-non-reasoning
# MNEMOSYNE_GROK_PRICE_PROMPT_PER_M=0
# MNEMOSYNE_GROK_PRICE_COMPLETION_PER_M=0

# Local fleet (when vision/arrange backends unset or ollama)
OLLAMA_HOST=http://localhost:11434
MNEMOSYNE_VISION_MODEL=qwen3-vl:32b
MNEMOSYNE_ARRANGE_MODEL=qwen3.6:35b

# --- Share links ---
MNEMOSYNE_SHARE_LINK_TTL_DAYS=30
MNEMOSYNE_MAX_ALBUM_UPLOAD=500